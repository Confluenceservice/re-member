          "content": {
            "size": 52456,
            "compression": 40624,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html><html lang=\"en\"> <head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Professional Membership Application</title><meta name=\"description\" content=\"Apply for Professional Membership with ELDAA.\"><link rel=\"stylesheet\" href=\"/_astro/BaseLayout.6LDkDhLP.css\"></head> <body class=\"font-sans text-gray-800 bg-gradient-to-b from-gray-50 to-indigo-100 min-h-screen\"> <main class=\"w-full max-w-5xl mx-auto px-4 py-4\">  <section class=\"bg-white border border-gray-200 rounded-xl p-4\"> <h1 class=\"text-2xl sm:text-4xl font-bold mb-1\">Professional Membership</h1> <p class=\"text-gray-600 m-0\">\nComplete all sections and upload required documents to apply.\n</p> </section>  <div id=\"step-indicator\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4 hidden\"> <div class=\"flex justify-between items-center mb-3\"> <span id=\"step-label\" class=\"font-semibold\">Step 1 of 8</span> <span id=\"step-name\" class=\"text-gray-600 text-sm\"></span> </div> <div id=\"step-dots\" class=\"grid grid-cols-4 sm:grid-cols-8 gap-2\"></div> </div>  <section id=\"section-register\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4\"> <h2 class=\"m-0 mb-4 text-xl\">Start Your Application</h2> <p class=\"text-gray-600 mb-4\">\nEnter your basic details to begin. You'll receive a unique link to resume your application.\n</p> <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-3\"> <div> <label for=\"reg-firstName\" class=\"block font-semibold mb-1.5\">First name</label> <input id=\"reg-firstName\" name=\"firstName\" type=\"text\" placeholder=\"Jane\" autocomplete=\"given-name\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> <div> <label for=\"reg-lastName\" class=\"block font-semibold mb-1.5\">Last name</label> <input id=\"reg-lastName\" name=\"lastName\" type=\"text\" placeholder=\"Doe\" autocomplete=\"family-name\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> </div> <div class=\"mt-3\"> <label for=\"reg-phone\" class=\"block font-semibold mb-1.5\">Phone number</label> <input id=\"reg-phone\" name=\"phone\" type=\"tel\" placeholder=\"+64 21 123 4567\" autocomplete=\"tel\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> <div class=\"mt-3\"> <label for=\"reg-email\" class=\"block font-semibold mb-1.5\">Email Address</label> <input id=\"reg-email\" name=\"email\" type=\"email\" placeholder=\"jane@example.com\" autocomplete=\"email\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> <button id=\"register-btn\" class=\"bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl shadow-lg mt-6 w-full\">\nStart Application\n</button> <p id=\"register-message\" class=\"mt-4 text-gray-600 hidden\"></p> </section>  <div id=\"loading-overlay\" class=\"fixed inset-0 bg-black/40 flex items-center justify-center z-50\"> <div class=\"bg-white rounded-xl p-8 flex flex-col items-center gap-4 shadow-xl\"> <div class=\"w-10 h-10 border-4 border-blue-600 border-t-transparent rounded-full animate-spin\"></div> <p class=\"text-gray-600 font-medium\">Loading your application...</p> </div> </div>  <section id=\"section-1\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4 hidden\"> <h2 class=\"m-0 mb-4 text-xl\">About You</h2> <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-3\"> <div> <label for=\"firstName\" class=\"block font-semibold mb-1.5\">First name *</label> <input id=\"firstName\" name=\"firstName\" type=\"text\" placeholder=\"Jane\" autocomplete=\"given-name\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> <div> <label for=\"lastName\" class=\"block font-semibold mb-1.5\">Last name *</label> <input id=\"lastName\" name=\"lastName\" type=\"text\" placeholder=\"Doe\" autocomplete=\"family-name\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> </div> <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3\"> <div> <label for=\"dateOfBirth\" class=\"block font-semibold mb-1.5\">Date of Birth *</label> <input id=\"dateOfBirth\" name=\"dateOfBirth\" type=\"text\" placeholder=\"DD/MM/YYYY\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> <div> <label for=\"ethnicity\" class=\"block font-semibold mb-1.5\">Ethnicity *</label> <input id=\"ethnicity\" name=\"ethnicity\" type=\"text\" placeholder=\"e.g. New Zealand European\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> </div> <div class=\"mt-3\"> <label for=\"address\" class=\"block font-semibold mb-1.5\">Address *</label> <input id=\"address\" name=\"address\" type=\"text\" placeholder=\"123 Main Street, Auckland, 1010\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> <div class=\"mt-3\"> <label for=\"postalAddress\" class=\"block font-semibold mb-1.5\">Postal Address</label> <input id=\"postalAddress\" name=\"postalAddress\" type=\"text\" placeholder=\"Optional — if different from above\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3\"> <div> <label for=\"phone\" class=\"block font-semibold mb-1.5\">Phone *</label> <input id=\"phone\" name=\"phone\" type=\"tel\" placeholder=\"+64 21 123 4567\" autocomplete=\"tel\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> <div> <label for=\"email\" class=\"block font-semibold mb-1.5\">Email *</label> <input id=\"email\" name=\"email\" type=\"email\" placeholder=\"jane@example.com\" autocomplete=\"email\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> </div> <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3\"> <div> <label for=\"businessName\" class=\"block font-semibold mb-1.5\">Business Name</label> <input id=\"businessName\" name=\"businessName\" type=\"text\" placeholder=\"Optional\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> <div> <label for=\"website\" class=\"block font-semibold mb-1.5\">Website / Social</label> <input id=\"website\" name=\"website\" type=\"text\" placeholder=\"Optional\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-lg\"> </div> </div> <div class=\"mt-6 flex gap-3 justify-end\"> <button class=\"bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl\" data-next=\"2\">Continue</button> </div> </section>  <section id=\"section-2\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4 hidden\"> <h2 class=\"m-0 mb-4 text-xl\">Your Training & Education</h2> <p class=\"text-gray-600 mb-4 text-sm\">\nList all End of Life Doula courses you have completed. Attach certificates separately in the Document Upload section.\n</p> <div id=\"courses-list\" class=\"flex flex-col gap-3\"></div> <button type=\"button\" id=\"add-course-btn\" class=\"bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg mt-3 w-full sm:w-auto\">\n+ Add Another Course\n</button> <div class=\"mt-6 flex gap-3 justify-end\"> <button class=\"bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg cursor-pointer\" data-goto=\"1\">Back</button> <button class=\"bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl\" data-next=\"3\">Continue</button> </div> </section>  <section id=\"section-3\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4 hidden\"> <h2 class=\"m-0 mb-4 text-xl\">Your EOL Doula Experience</h2> <div id=\"experience-list\" class=\"flex flex-col gap-3 mb-4\"></div> <button type=\"button\" id=\"add-experience-btn\" class=\"bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg w-full sm:w-auto\">+ Add Experience</button> <h3 class=\"mt-6 mb-3 text-lg\">Example 1 *</h3> <p class=\"text-gray-600 text-sm mb-3\">Describe an example including setting/context, role, skills used, ethical/cultural considerations, and outcome/learning.</p> <textarea id=\"example1\" rows=\"4\" placeholder=\"Describe your experience...\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-base resize-y\"></textarea> <h3 class=\"mt-4 mb-3 text-lg\">Example 2</h3> <textarea id=\"example2\" rows=\"4\" placeholder=\"Optional second example...\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-base resize-y\"></textarea> <h3 class=\"mt-4 mb-3 text-lg\">Example 3</h3> <textarea id=\"example3\" rows=\"4\" placeholder=\"Optional third example...\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-base resize-y\"></textarea> <div class=\"mt-6 flex gap-3 justify-end\"> <button class=\"bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg cursor-pointer\" data-goto=\"2\">Back</button> <button class=\"bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl\" data-next=\"4\">Continue</button> </div> </section>  <section id=\"section-4\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4 hidden\"> <h2 class=\"m-0 mb-4 text-xl\">Further Requirements</h2> <div class=\"flex flex-col gap-3\"> <div class=\"p-3 border border-gray-200 rounded-lg\"> <p class=\"font-semibold mb-2\">Do you agree to actively provide Doula Services? *</p> <div class=\"flex gap-6\"> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"agreeDoulaServices\" value=\"YES\"> Yes</label> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"agreeDoulaServices\" value=\"NO\"> No</label> </div> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <p class=\"font-semibold mb-2\">Do you agree to an interview by one or more committee members? *</p> <div class=\"flex gap-6\"> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"agreeInterview\" value=\"YES\"> Yes</label> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"agreeInterview\" value=\"NO\"> No</label> </div> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <p class=\"font-semibold mb-2\">Do you agree to submit proof of up to 10 hours of professional development each year? *</p> <div class=\"flex gap-6\"> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"commitProfessionalDev\" value=\"YES\"> Yes</label> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"commitProfessionalDev\" value=\"NO\"> No</label> </div> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <p class=\"font-semibold mb-2\">Will you take out professional indemnity insurance? (recommended)</p> <div class=\"flex gap-6\"> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"willInsurance\" value=\"YES\"> Yes</label> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"willInsurance\" value=\"NO\"> No</label> </div> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <p class=\"font-semibold mb-2\">Do you wish to be listed as a practicing End of Life Doula in our directory? *</p> <div class=\"flex gap-6\"> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"listDirectory\" value=\"YES\"> Yes</label> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"listDirectory\" value=\"NO\"> No</label> </div> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <p class=\"font-semibold mb-2\">Are you willing to provide a current Ministry of Justice criminal record check? *</p> <div class=\"flex gap-6\"> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"provideCriminalCheck\" value=\"YES\"> Yes</label> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"provideCriminalCheck\" value=\"NO\"> No</label> </div> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <p class=\"font-semibold mb-2\">Are you willing to attend regular ELDAA meetings and events, and engage with and support your local ELDAA community? *</p> <div class=\"flex gap-6\"> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"attendMeetings\" value=\"YES\"> Yes</label> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"attendMeetings\" value=\"NO\"> No</label> </div> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <p class=\"font-semibold mb-2\">Are you willing to work remotely where there is no other available Professional Member in a Client's area? *</p> <div class=\"flex gap-6\"> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"workRemotely\" value=\"YES\"> Yes</label> <label class=\"flex items-center gap-2 cursor-pointer\"><input type=\"radio\" name=\"workRemotely\" value=\"NO\"> No</label> </div> </div> </div> <div class=\"mt-6 flex gap-3 justify-end\"> <button class=\"bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg cursor-pointer\" data-goto=\"3\">Back</button> <button class=\"bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl\" data-next=\"5\">Continue</button> </div> </section>  <section id=\"section-5\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4 hidden\"> <h2 class=\"m-0 mb-4 text-xl\">EOL Doula Standards & Core Competencies</h2> <p class=\"text-gray-600 mb-4 text-sm\">Please tick the competencies you are confident in providing.</p> <div id=\"competencies-grid\" class=\"grid grid-cols-1 sm:grid-cols-2 gap-2\"></div> <div class=\"mt-6 flex gap-3 justify-end\"> <button class=\"bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg cursor-pointer\" data-goto=\"4\">Back</button> <button class=\"bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl\" data-next=\"6\">Continue</button> </div> </section>  <section id=\"section-6\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4 hidden\"> <h2 class=\"m-0 mb-4 text-xl\">Referees</h2> <p class=\"text-gray-600 mb-4 text-sm\">Please provide two referees who have witnessed your work with the dying, or who have worked alongside you in a related field.</p> <h3 class=\"m-0 mb-3 text-lg\">Referee 1 *</h3> <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-3\"> <div> <label for=\"ref1Name\" class=\"block font-semibold mb-1\">Full Name *</label> <input id=\"ref1Name\" type=\"text\" placeholder=\"Full name\" class=\"w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base\"> </div> <div> <label for=\"ref1Role\" class=\"block font-semibold mb-1\">Role / Relationship *</label> <input id=\"ref1Role\" type=\"text\" placeholder=\"e.g. Nurse, Social Worker\" class=\"w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base\"> </div> <div> <label for=\"ref1Email\" class=\"block font-semibold mb-1\">Email *</label> <input id=\"ref1Email\" type=\"email\" placeholder=\"referee@example.com\" class=\"w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base\"> </div> <div> <label for=\"ref1Phone\" class=\"block font-semibold mb-1\">Phone *</label> <input id=\"ref1Phone\" type=\"tel\" placeholder=\"+64 21 123 4567\" class=\"w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base\"> </div> </div> <h3 class=\"mt-6 mb-3 text-lg\">Referee 2 *</h3> <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-3\"> <div> <label for=\"ref2Name\" class=\"block font-semibold mb-1\">Full Name *</label> <input id=\"ref2Name\" type=\"text\" placeholder=\"Full name\" class=\"w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base\"> </div> <div> <label for=\"ref2Role\" class=\"block font-semibold mb-1\">Role / Relationship *</label> <input id=\"ref2Role\" type=\"text\" placeholder=\"e.g. Nurse, Social Worker\" class=\"w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base\"> </div> <div> <label for=\"ref2Email\" class=\"block font-semibold mb-1\">Email *</label> <input id=\"ref2Email\" type=\"email\" placeholder=\"referee@example.com\" class=\"w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base\"> </div> <div> <label for=\"ref2Phone\" class=\"block font-semibold mb-1\">Phone *</label> <input id=\"ref2Phone\" type=\"tel\" placeholder=\"+64 21 123 4567\" class=\"w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base\"> </div> </div> <div class=\"mt-6 flex gap-3 justify-end\"> <button class=\"bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg cursor-pointer\" data-goto=\"5\">Back</button> <button class=\"bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl\" data-next=\"7\">Continue</button> </div> </section>  <section id=\"section-7\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4 hidden\"> <h2 class=\"m-0 mb-4 text-xl\">Declarations</h2> <p class=\"text-gray-600 mb-4 text-sm\">Please confirm all statements below to proceed.</p> <div class=\"flex flex-col gap-3\"> <div class=\"p-3 border border-gray-200 rounded-lg\"> <label class=\"flex items-start gap-2 cursor-pointer\"> <input type=\"checkbox\" id=\"declAccuracy\" class=\"mt-1\"> <span>I confirm the information provided is accurate and complete. *</span> </label> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <label class=\"flex items-start gap-2 cursor-pointer\"> <input type=\"checkbox\" id=\"declEthics\" class=\"mt-1\"> <span>I have read and agree to the ELDAA Code of Ethics. *</span> </label> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <label class=\"flex items-start gap-2 cursor-pointer\"> <input type=\"checkbox\" id=\"declScope\" class=\"mt-1\"> <span>I have read and understand the Scope of Practice. *</span> </label> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <label class=\"flex items-start gap-2 cursor-pointer\"> <input type=\"checkbox\" id=\"declDoulaServices\" class=\"mt-1\"> <span>I agree to actively provide Doula Services as part of my professional membership. *</span> </label> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <label class=\"flex items-start gap-2 cursor-pointer\"> <input type=\"checkbox\" id=\"declInterview\" class=\"mt-1\"> <span>I agree to an interview by the committee if required. *</span> </label> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <label class=\"flex items-start gap-2 cursor-pointer\"> <input type=\"checkbox\" id=\"declProfessionalDev\" class=\"mt-1\"> <span>I commit to completing 10 hours of professional development per year. *</span> </label> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <label class=\"flex items-start gap-2 cursor-pointer\"> <input type=\"checkbox\" id=\"declCriminalCheck\" class=\"mt-1\"> <span>I agree to provide a Ministry of Justice criminal record check. *</span> </label> </div> <div class=\"p-3 border border-gray-200 rounded-lg\"> <label class=\"flex items-start gap-2 cursor-pointer\"> <input type=\"checkbox\" id=\"declMeetings\" class=\"mt-1\"> <span>I agree to attend regular ELDAA meetings and support my local community. *</span> </label> </div> </div> <div class=\"mt-6 flex gap-3 justify-end\"> <button class=\"bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg cursor-pointer\" data-goto=\"6\">Back</button> <button class=\"bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl\" data-next=\"8\">Continue to Documents</button> </div> </section>  <section id=\"section-8\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4 hidden\"> <h2 class=\"m-0 mb-4 text-xl\">Document Upload</h2> <p class=\"text-gray-600 mb-6 text-sm\">Upload your supporting documents below. You can upload multiple files per category.</p> <div id=\"progress-info\" class=\"mb-6 p-4 bg-gray-50 rounded-lg\"> <p class=\"m-0 mb-2 font-semibold\">Documents: <span id=\"upload-count\">0</span> / 6 required categories</p> <p id=\"upload-status-text\" class=\"m-0 text-gray-600 text-sm\"></p> </div> <div id=\"document-list\" class=\"flex flex-col gap-4\"></div> <div id=\"payment-section\" class=\"mt-8 pt-6 border-t border-gray-200\"> <button id=\"proceed-payment-btn\" class=\"bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl shadow-lg w-full\" disabled>\nComplete all sections to continue\n</button> </div> <div class=\"mt-6 flex gap-3 justify-start\"> <button class=\"bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg cursor-pointer\" data-goto=\"7\">Back</button> </div> </section>  <section id=\"paid-section\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4 hidden\"> <h2 class=\"m-0 mb-4 text-xl\">Application Complete</h2> <p>Your Professional Membership application has been completed. Thank you!</p> <p class=\"mt-4\"> <a href=\"https://eldaa.org.nz\" class=\"text-blue-600 hover:text-blue-700\">Return to ELDAA website</a> </p> </section>  <section id=\"error-section\" class=\"bg-white border border-gray-200 rounded-xl p-4 mt-4 hidden\"> <h2 class=\"m-0 mb-4 text-amber-800\">Error</h2> <p id=\"error-message\"></p> <a href=\"/professional/apply\" class=\"bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl shadow-lg inline-block mt-4\">Start New Application</a> </section>  </main> </body></html> <script>(function(){const token = \"2141cc78-e01f-41c5-bc7b-7163136b6f8b\";\n\n  const STEPS = [\n    { id: \"section-register\", label: \"Start\" },\n    { id: \"section-1\", label: \"About You\" },\n    { id: \"section-2\", label: \"Training\" },\n    { id: \"section-3\", label: \"Experience\" },\n    { id: \"section-4\", label: \"Requirements\" },\n    { id: \"section-5\", label: \"Competencies\" },\n    { id: \"section-6\", label: \"Referees\" },\n    { id: \"section-7\", label: \"Declarations\" },\n    { id: \"section-8\", label: \"Documents\" },\n  ];\n\n  const REQUIRED_DOCS = [\n    { id: \"training\", label: \"Certificates of Training\", description: \"Evidence of completed training\" },\n    { id: \"ethics\", label: \"Code of Ethics\", description: \"Signed ELDAA Code of Ethics and Scope of Practice\" },\n    { id: \"criminal\", label: \"Criminal Records Check\", description: \"Ministry of Justice background check\" },\n    { id: \"advance_care\", label: \"Advanced Care Planning (NZ)\", description: \"4 modules completed\" },\n    { id: \"assisted_dying\", label: \"Assisted Dying Training\", description: \"Te Whatu Ora, 3 modules completed\" },\n    { id: \"fundamentals\", label: \"Fundamentals of Palliative Care\", description: \"Hospice NZ, 4 online modules\" },\n  ];\n\n  const OPTIONAL_DOCS = [\n    { id: \"insurance\", label: \"Professional Indemnity Insurance\", description: \"Optional but recommended\" },\n  ];\n\n  const COMPETENCIES = [\n    \"Effective Communication Skills — deep listening, open-ended questioning, holding space\",\n    \"Advocacy & Empowerment — navigating medical/healthcare systems\",\n    \"Understanding of Cultural & Spiritual Diversity\",\n    \"Shows initiative — anticipate needs, seek information\",\n    \"Compassionate Presence — quiet, calm presence, follow the lead\",\n    \"Ongoing Education & Development\",\n    \"Self-Care & Professional Boundaries\",\n    \"Knowledge of End-of-Life Options — palliative care, hospice, VAD, home death\",\n    \"Business acumen — contractual agreement, sliding scale, timely invoices\",\n    \"Networking & Referrals\",\n    \"Holistic support — emotional, spiritual, cultural, practical, social\",\n    \"Illness journey advocacy and empowerment\",\n    \"Legacy & Life Review\",\n    \"Holistic Advance Care Planning\",\n    \"Vigil Planning & Support\",\n    \"Practical Assistance during illness\",\n    \"Funeral & Memorial Planning\",\n    \"Body care and After Death care\",\n    \"Grief & Bereavement Awareness\",\n    \"Interdisciplinary Collaboration\",\n    \"Mentorship — willing to mentor other ELDAA members\",\n  ];\n\n  let currentStep = 0;\n  let applicantId = null;\n  let courses = [];\n  let experiences = [];\n  let competencyStates = {};\n  let stepCompletion = {};  // step index -> true if completed\n\n  function markStepComplete(stepIdx) {\n    // Token-based resume: step 0 is always \"complete\" since data was pre-filled server-side\n    if (stepIdx === 0 && token) { stepCompletion[0] = true; updateDots(); return; }\n    if (validateStep(stepIdx)) {\n      stepCompletion[stepIdx] = true;\n      updateDots();\n    }\n  }\n  function isStepComplete(stepIdx) { return !!stepCompletion[stepIdx]; }\n  function completedCount() { return Object.keys(stepCompletion).length; }\n\n  function updateDots() {\n    const dotsContainer = document.getElementById(\"step-dots\");\n    if (!dotsContainer) return;\n    dotsContainer.innerHTML = \"\";\n    for (let i = 1; i <= 8; i++) {\n      const dot = document.createElement(\"button\");\n      dot.className = \"flex flex-col items-center gap-1 p-1 rounded focus:outline-none focus:ring-2 focus:ring-blue-300\";\n      const isCurrent = i === currentStep;\n      const isDone = isStepComplete(i);\n      dot.innerHTML = `\n        <div class=\"w-8 h-2 rounded-full transition-colors duration-200 ${isDone ? \"bg-emerald-700\" : isCurrent ? \"bg-blue-600\" : \"bg-gray-200\"}\"></div>\n        <span class=\"text-xs font-medium ${isDone ? \"text-emerald-700\" : isCurrent ? \"text-blue-600\" : \"text-gray-400\"}\">${STEPS[i]?.label || \"\"}</span>\n      `;\n      dot.addEventListener(\"click\", () => showStep(i));\n      dotsContainer.appendChild(dot);\n    }\n  }\n\n  function showStep(n) {\n    // Auto-mark previous step complete when advancing\n    if (n > currentStep && currentStep > 0) markStepComplete(currentStep);\n\n    document.querySelectorAll(\"section\").forEach(s => s.classList.add(\"hidden\"));\n    const section = document.getElementById(STEPS[n].id);\n    if (section) section.classList.remove(\"hidden\");\n\n    const indicator = document.getElementById(\"step-indicator\");\n    if (indicator) {\n      indicator.classList.toggle(\"hidden\", n === 0);\n      document.getElementById(\"step-label\").textContent = `Step ${Math.min(n, 8)} of 8`;\n      document.getElementById(\"step-name\").textContent = STEPS[n]?.label || \"\";\n      updateDots();\n    }\n\n    currentStep = n;\n    if (n === 8) renderDocuments();\n  }\n\n  function buildCompetencyGrid() {\n    const grid = document.getElementById(\"competencies-grid\");\n    grid.innerHTML = \"\";\n    COMPETENCIES.forEach((comp, i) => {\n      const item = document.createElement(\"div\");\n      const checked = competencyStates[i];\n      item.className = \"px-3 py-2 border rounded-md text-sm \" + (checked ? \"border-emerald-700 bg-emerald-50\" : \"border-gray-200\");\n      item.innerHTML = `<label class=\"flex items-center gap-2 cursor-pointer\">\n        <input type=\"checkbox\" data-comp=\"${i}\" ${checked ? \"checked\" : \"\"} />\n        <span>${comp}</span>\n      </label>`;\n      item.querySelector(\"input\").addEventListener(\"change\", (e) => {\n        competencyStates[i] = e.target.checked;\n        item.className = \"px-3 py-2 border rounded-md text-sm \" + (e.target.checked ? \"border-emerald-700 bg-emerald-50\" : \"border-gray-200\");\n      });\n      grid.appendChild(item);\n    });\n  }\n\n  function addCourseRow(data = {}) {\n    const list = document.getElementById(\"courses-list\");\n    const idx = courses.length;\n    courses.push(data);\n    const row = document.createElement(\"div\");\n    row.className = \"p-3 border border-gray-200 rounded-lg bg-gray-50\";\n    row.id = `course-${idx}`;\n    row.innerHTML = `\n      <div class=\"grid grid-cols-1 sm:grid-cols-4 gap-2 items-end\">\n        <div>\n          <label class=\"text-xs font-semibold block mb-1\">Course Name *</label>\n          <input type=\"text\" data-course=\"name\" value=\"${data.name || \"\"}\" placeholder=\"e.g. EOL Doula Foundation\"\n            class=\"w-full px-3 py-2 border border-gray-200 rounded-md text-sm\" />\n        </div>\n        <div>\n          <label class=\"text-xs font-semibold block mb-1\">Provider *</label>\n          <input type=\"text\" data-course=\"provider\" value=\"${data.provider || \"\"}\" placeholder=\"e.g. ELDAA\"\n            class=\"w-full px-3 py-2 border border-gray-200 rounded-md text-sm\" />\n        </div>\n        <div>\n          <label class=\"text-xs font-semibold block mb-1\">Year *</label>\n          <input type=\"text\" data-course=\"year\" value=\"${data.year || \"\"}\" placeholder=\"2024\"\n            class=\"w-full px-3 py-2 border border-gray-200 rounded-md text-sm\" />\n        </div>\n        <div class=\"flex justify-end\">\n          <button type=\"button\" class=\"remove-course px-3 py-2 border border-amber-700 text-amber-800 rounded-md bg-white text-sm font-medium cursor-pointer\"\n            data-idx=\"${idx}\">&times;</button>\n        </div>\n      </div>`;\n    row.querySelector(\".remove-course\").addEventListener(\"click\", () => {\n      courses[idx] = null;\n      row.style.display = \"none\";\n    });\n    list.appendChild(row);\n  }\n\n  document.getElementById(\"add-course-btn\").addEventListener(\"click\", () => addCourseRow());\n\n  function addExperienceRow(data = {}) {\n    const list = document.getElementById(\"experience-list\");\n    const idx = experiences.length;\n    experiences.push(data);\n    const row = document.createElement(\"div\");\n    row.className = \"p-3 border border-gray-200 rounded-lg bg-gray-50\";\n    row.id = `exp-${idx}`;\n    row.innerHTML = `\n      <div class=\"flex flex-col gap-2\">\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-2\">\n          <div>\n            <label class=\"text-xs font-semibold block mb-1\">Role / Context *</label>\n            <textarea data-exp=\"role\" rows=\"2\" placeholder=\"Describe the role or context\"\n              class=\"w-full px-3 py-2 border border-gray-200 rounded-md text-sm resize-y\">${data.role || \"\"}</textarea>\n          </div>\n          <div>\n            <label class=\"text-xs font-semibold block mb-1\">Skills that relate to EOL *</label>\n            <textarea data-exp=\"skills\" rows=\"2\" placeholder=\"Skills used\"\n              class=\"w-full px-3 py-2 border border-gray-200 rounded-md text-sm resize-y\">${data.skills || \"\"}</textarea>\n          </div>\n        </div>\n        <div class=\"flex justify-end\">\n          <button type=\"button\" class=\"remove-exp px-3 py-1 border border-amber-700 text-amber-800 rounded bg-white text-xs font-medium cursor-pointer\"\n            data-idx=\"${idx}\">Remove</button>\n        </div>\n      </div>`;\n    row.querySelector(\".remove-exp\").addEventListener(\"click\", () => {\n      experiences[idx] = null;\n      row.style.display = \"none\";\n    });\n    list.appendChild(row);\n  }\n\n  document.getElementById(\"add-experience-btn\").addEventListener(\"click\", () => addExperienceRow());\n\n  let saveQueue = Promise.resolve();\n  function queueFormSave() {\n    saveQueue = saveQueue.then(() => saveFormData()).catch(() => {});\n    return saveQueue;\n  }\n\n  async function saveFormData() {\n    const activeToken = window.__token__ || token;\n    if (!window.__applicantId__ && !activeToken) return;\n\n    try {\n      const payload = {\n        token: activeToken || \"\",\n        firstName: document.getElementById(\"firstName\")?.value?.trim() || \"\",\n        lastName: document.getElementById(\"lastName\")?.value?.trim() || \"\",\n        phone: document.getElementById(\"phone\")?.value?.trim() || \"\",\n        email: document.getElementById(\"email\")?.value?.trim() || \"\",\n        dateOfBirth: document.getElementById(\"dateOfBirth\")?.value || \"\",\n        ethnicity: document.getElementById(\"ethnicity\")?.value || \"\",\n        address: document.getElementById(\"address\")?.value || \"\",\n        postalAddress: document.getElementById(\"postalAddress\")?.value || \"\",\n        businessName: document.getElementById(\"businessName\")?.value || \"\",\n        website: document.getElementById(\"website\")?.value || \"\",\n        qualifications: JSON.stringify(courses.filter(Boolean).map(c => ({\n          name: document.querySelector(`#course-${courses.indexOf(c)} [data-course=\"name\"]`)?.value || c.name,\n          provider: document.querySelector(`#course-${courses.indexOf(c)} [data-course=\"provider\"]`)?.value || c.provider,\n          year: document.querySelector(`#course-${courses.indexOf(c)} [data-course=\"year\"]`)?.value || c.year,\n        }))),\n        experience: JSON.stringify(experiences.filter(Boolean).map(e => ({\n          role: document.querySelector(`#exp-${experiences.indexOf(e)} [data-exp=\"role\"]`)?.value || e.role,\n          skills: document.querySelector(`#exp-${experiences.indexOf(e)} [data-exp=\"skills\"]`)?.value || e.skills,\n        }))),\n        furtherRequirements: JSON.stringify({\n          agreeDoulaServices: document.querySelector('input[name=\"agreeDoulaServices\"]:checked')?.value || \"\",\n          agreeInterview: document.querySelector('input[name=\"agreeInterview\"]:checked')?.value || \"\",\n          commitProfessionalDev: document.querySelector('input[name=\"commitProfessionalDev\"]:checked')?.value || \"\",\n          willInsurance: document.querySelector('input[name=\"willInsurance\"]:checked')?.value || \"\",\n          listDirectory: document.querySelector('input[name=\"listDirectory\"]:checked')?.value || \"\",\n          provideCriminalCheck: document.querySelector('input[name=\"provideCriminalCheck\"]:checked')?.value || \"\",\n          attendMeetings: document.querySelector('input[name=\"attendMeetings\"]:checked')?.value || \"\",\n          workRemotely: document.querySelector('input[name=\"workRemotely\"]:checked')?.value || \"\",\n        }),\n        coreCompetencies: JSON.stringify(Object.values(competencyStates)),\n        referee1Name: document.getElementById(\"ref1Name\")?.value || \"\",\n        referee1Role: document.getElementById(\"ref1Role\")?.value || \"\",\n        referee1Email: document.getElementById(\"ref1Email\")?.value || \"\",\n        referee1Phone: document.getElementById(\"ref1Phone\")?.value || \"\",\n        referee2Name: document.getElementById(\"ref2Name\")?.value || \"\",\n        referee2Role: document.getElementById(\"ref2Role\")?.value || \"\",\n        referee2Email: document.getElementById(\"ref2Email\")?.value || \"\",\n        referee2Phone: document.getElementById(\"ref2Phone\")?.value || \"\",\n        declarationAccuracy: document.getElementById(\"declAccuracy\")?.checked ? \"TRUE\" : \"\",\n        declarationEthics: document.getElementById(\"declEthics\")?.checked ? \"TRUE\" : \"\",\n        declarationScope: document.getElementById(\"declScope\")?.checked ? \"TRUE\" : \"\",\n        declarationDoulaServices: document.getElementById(\"declDoulaServices\")?.checked ? \"TRUE\" : \"\",\n        declarationInterview: document.getElementById(\"declInterview\")?.checked ? \"TRUE\" : \"\",\n        declarationProfessionalDev: document.getElementById(\"declProfessionalDev\")?.checked ? \"TRUE\" : \"\",\n        declarationCriminalCheck: document.getElementById(\"declCriminalCheck\")?.checked ? \"TRUE\" : \"\",\n        declarationMeetings: document.getElementById(\"declMeetings\")?.checked ? \"TRUE\" : \"\",\n        declarationSignedAt: new Date().toISOString(),\n      };\n\n      const response = await fetch(\"/api/professional/apply\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(payload)\n      });\n      if (!response.ok) return;\n\n      const data = await response.json();\n      if (data.applicantId) {\n        applicantId = data.applicantId;\n        window.__applicantId__ = data.applicantId;\n      }\n      if (data.resumeLink) {\n        window.__token__ = data.resumeLink?.split(\"token=\")[1] || activeToken;\n      }\n    } catch {}\n  }\n\n  document.querySelectorAll(\"[data-next]\").forEach(btn => {\n    btn.addEventListener(\"click\", async () => {\n      saveStepData(currentStep);\n      await queueFormSave();\n      showStep(parseInt(btn.dataset.next));\n    });\n  });\n\n  document.querySelectorAll(\"[data-goto]\").forEach(btn => {\n    btn.addEventListener(\"click\", async () => {\n      await queueFormSave();\n      showStep(parseInt(btn.dataset.goto));\n    });\n  });\n\n  function validateStep(n) {\n    if (n === 0) {\n      const f = document.getElementById(\"reg-firstName\").value.trim();\n      const l = document.getElementById(\"reg-lastName\").value.trim();\n      const e = document.getElementById(\"reg-email\").value.trim();\n      if (!f || !l || !e) { alert(\"Please fill in your name and email.\"); return false; }\n      return true;\n    }\n    if (n === 1) return true;\n    if (n === 2) return true;\n    if (n === 4) {\n      const required = [\"agreeDoulaServices\", \"agreeInterview\", \"commitProfessionalDev\", \"listDirectory\", \"provideCriminalCheck\", \"attendMeetings\", \"workRemotely\"];\n      for (const id of required) {\n        const el = document.getElementById(id);\n        if (el && !el.checked) {\n          alert(\"Please answer all required questions.\");\n          return false;\n        }\n      }\n      return true;\n    }\n    if (n === 5) return true;\n    if (n === 6) {\n      const fields = [\"ref1Name\", \"ref1Role\", \"ref1Email\", \"ref1Phone\", \"ref2Name\", \"ref2Role\", \"ref2Email\", \"ref2Phone\"];\n      for (const id of fields) {\n        const el = document.getElementById(id);\n        if (el && !el.value.trim()) {\n          alert(\"Please fill in all referee fields.\");\n          return false;\n        }\n      }\n      return true;\n    }\n    if (n === 7) {\n      const decls = [\"declAccuracy\", \"declEthics\", \"declScope\", \"declDoulaServices\", \"declInterview\", \"declProfessionalDev\", \"declCriminalCheck\", \"declMeetings\"];\n      for (const id of decls) {\n        const el = document.getElementById(id);\n        if (el && !el.checked) {\n          alert(\"Please confirm all declarations to proceed.\");\n          return false;\n        }\n      }\n      return true;\n    }\n    return true;\n  }\n\n  function saveStepData(n) {}\n\n  function renderDocuments() {\n    const uploaded = window.__docsUploaded__ || {};\n    const allDocs = [...REQUIRED_DOCS, ...OPTIONAL_DOCS];\n    const list = document.getElementById(\"document-list\");\n    list.innerHTML = \"\";\n\n    let requiredComplete = 0;\n    allDocs.forEach(doc => {\n      const files = uploaded[doc.id] || [];\n      const isRequired = REQUIRED_DOCS.some(d => d.id === doc.id);\n      const isUploaded = files.length > 0;\n      if (isRequired && isUploaded) requiredComplete++;\n\n      const item = document.createElement(\"div\");\n      const borderColor = isUploaded ? \"border-emerald-700\" : \"border-gray-200\";\n      const bgColor = isUploaded ? \"bg-emerald-50\" : \"bg-white\";\n      item.className = `p-4 border rounded-lg ${borderColor} ${bgColor}`;\n\n      let filesHtml = \"\";\n      files.forEach(f => {\n        filesHtml += `<div class=\"flex justify-between items-center py-2 border-b border-gray-200\">\n          <div class=\"flex items-center gap-2\">\n            <span class=\"text-sm\">${f.filename}</span>\n            <span class=\"text-xs text-gray-500\">${new Date(f.uploadedAt).toLocaleDateString()}</span>\n          </div>\n          <button class=\"delete-file-btn px-2 py-1 border border-amber-700 text-amber-800 rounded text-xs font-medium bg-white cursor-pointer\"\n            data-fileid=\"${f.fileId}\" data-doctype=\"${doc.id}\">Delete</button>\n        </div>`;\n      });\n\n      const badgeBg = isUploaded ? \"bg-emerald-700\" : \"bg-gray-100\";\n      const badgeColor = isUploaded ? \"text-white\" : \"text-gray-600\";\n      item.innerHTML = `\n        <div class=\"flex justify-between items-center mb-3\">\n          <div>\n            <p class=\"font-semibold m-0\">${doc.label} ${isRequired ? \"*\" : \"(optional)\"}</p>\n            <p class=\"m-0 mt-1 text-gray-600 text-sm\">${doc.description}</p>\n          </div>\n          <span class=\"px-2 py-1 rounded text-xs font-semibold ${badgeBg} ${badgeColor}\">${isUploaded ? files.length + \" file(s)\" : \"Required\"}</span>\n        </div>\n        ${filesHtml}\n        <div class=\"mt-3\">\n          <input type=\"file\" id=\"file-${doc.id}\" accept=\".pdf,.jpg,.jpeg,.png,.gif,.doc,.docx\" class=\"hidden\" />\n          <button class=\"upload-btn px-4 py-2 border border-blue-600 text-blue-600 rounded-md bg-white text-sm font-medium cursor-pointer hover:bg-blue-50\"\n            data-doc=\"${doc.id}\">${isUploaded ? \"Upload More\" : \"Choose File\"}</button>\n        </div>`;\n      list.appendChild(item);\n    });\n\n    document.getElementById(\"upload-count\").textContent = requiredComplete;\n    document.getElementById(\"upload-status-text\").textContent =\n      requiredComplete === 6 ? \"All required documents uploaded!\" : `${6 - requiredComplete} category(ies) remaining`;\n\n    const paymentBtn = document.getElementById(\"proceed-payment-btn\");\n    if (requiredComplete === 6) {\n      paymentBtn.disabled = false;\n      paymentBtn.textContent = \"Proceed to Payment\";\n      paymentBtn.onclick = goToPayment;\n    }\n\n    setupUploadHandlers();\n    setupDeleteHandlers();\n  }\n\n  function setupUploadHandlers() {\n    document.querySelectorAll(\".upload-btn\").forEach(btn => {\n      btn.addEventListener(\"click\", () => {\n        const docId = btn.dataset.doc;\n        document.getElementById(`file-${docId}`).click();\n      });\n    });\n\n    document.querySelectorAll(\"input[type=file]\").forEach(input => {\n      input.addEventListener(\"change\", async (e) => {\n        const docId = e.target.id.replace(\"file-\", \"\");\n        const file = e.target.files[0];\n        if (!file) return;\n\n        const btn = document.querySelector(`.upload-btn[data-doc=\"${docId}\"]`);\n        btn.disabled = true;\n        btn.textContent = \"Uploading...\";\n\n        try {\n          const arrayBuffer = await file.arrayBuffer();\n          const base64 = btoa(String.fromCharCode(...new Uint8Array(arrayBuffer)));\n\n          const res = await fetch(\"/api/professional/upload-file\", {\n            method: \"POST\",\n            headers: { \"Content-Type\": \"application/json\" },\n            body: JSON.stringify({\n              token: window.__token__ || token,\n              docType: docId,\n              filename: file.name,\n              mimeType: file.type,\n              data: base64,\n            })\n          });\n\n          const data = await res.json();\n          if (data.success) {\n            if (!window.__docsUploaded__[docId]) window.__docsUploaded__[docId] = [];\n            window.__docsUploaded__[docId].push({ fileId: data.fileId || data.filename, filename: file.name, uploadedAt: new Date().toISOString() });\n            renderDocuments();\n          } else {\n            btn.disabled = false;\n            btn.textContent = \"Upload More\";\n            alert(data.error || \"Upload failed\");\n          }\n        } catch (err) {\n          btn.disabled = false;\n          btn.textContent = \"Upload More\";\n          alert(\"Upload failed\");\n        }\n      });\n    });\n  }\n\n  function setupDeleteHandlers() {\n    document.querySelectorAll(\".delete-file-btn\").forEach(btn => {\n      btn.addEventListener(\"click\", async () => {\n        const fileId = btn.dataset.fileid;\n        const docType = btn.dataset.doctype;\n        if (!confirm(\"Delete this file?\")) return;\n        btn.textContent = \"...\";\n        btn.disabled = true;\n\n        try {\n          const res = await fetch(\"/api/professional/delete-file\", {\n            method: \"POST\",\n            headers: { \"Content-Type\": \"application/json\" },\n            body: JSON.stringify({ fileId, token: window.__token__ || token })\n          });\n          const data = await res.json();\n          if (data.success) {\n            window.__docsUploaded__[docType] = (window.__docsUploaded__[docType] || []).filter(f => f.fileId !== fileId);\n            renderDocuments();\n          } else {\n            btn.textContent = \"Delete\";\n            btn.disabled = false;\n            alert(data.error || \"Delete failed\");\n          }\n        } catch {\n          btn.textContent = \"Delete\";\n          btn.disabled = false;\n          alert(\"Delete failed\");\n        }\n      });\n    });\n  }\n\n  async function goToPayment() {\n    const btn = document.getElementById(\"proceed-payment-btn\");\n    btn.disabled = true;\n    btn.textContent = \"Loading...\";\n\n    try {\n      const res = await fetch(\"/api/professional/upload-complete\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ token: window.__token__ || token })\n      });\n\n      const data = await res.json();\n      if (data.url) {\n        window.location.href = data.url;\n      } else {\n        btn.disabled = false;\n        btn.textContent = \"Proceed to Payment\";\n        alert(data.error || \"Failed to create payment session\");\n      }\n    } catch (err) {\n      btn.disabled = false;\n      btn.textContent = \"Proceed to Payment\";\n      alert(\"Failed to create payment session\");\n    }\n  }\n\n  document.getElementById(\"register-btn\").addEventListener(\"click\", async () => {\n    const firstName = document.getElementById(\"reg-firstName\").value.trim();\n    const lastName = document.getElementById(\"reg-lastName\").value.trim();\n    const phone = document.getElementById(\"reg-phone\").value.trim();\n    const email = document.getElementById(\"reg-email\").value.trim();\n\n    if (!firstName || !lastName || !email) {\n      document.getElementById(\"register-message\").textContent = \"Please enter your first name, last name, and email.\";\n      document.getElementById(\"register-message\").classList.remove(\"hidden\");\n      return;\n    }\n\n    const btn = document.getElementById(\"register-btn\");\n    btn.disabled = true;\n    btn.textContent = \"Sending...\";\n\n    try {\n      const res = await fetch(\"/api/professional/apply\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          firstName,\n          lastName,\n          phone,\n          email,\n          dateOfBirth: \"\",\n          ethnicity: \"\",\n          address: \"\",\n          postalAddress: \"\",\n          businessName: \"\",\n          website: \"\",\n          qualifications: \"[]\",\n          experience: \"[]\",\n          furtherRequirements: \"{}\",\n          coreCompetencies: \"[]\",\n          referee1Name: \"\",\n          referee1Role: \"\",\n          referee1Email: \"\",\n          referee1Phone: \"\",\n          referee2Name: \"\",\n          referee2Role: \"\",\n          referee2Email: \"\",\n          referee2Phone: \"\",\n          declarationAccuracy: \"\",\n          declarationEthics: \"\",\n          declarationScope: \"\",\n          declarationDoulaServices: \"\",\n          declarationInterview: \"\",\n          declarationProfessionalDev: \"\",\n          declarationCriminalCheck: \"\",\n          declarationMeetings: \"\",\n          declarationSignedAt: new Date().toISOString(),\n        })\n      });\n\n      const data = await res.json();\n      if (data.success) {\n        applicantId = data.applicantId;\n        window.__applicantId__ = data.applicantId;\n        window.__token__ = data.resumeLink?.split(\"token=\")[1] || token;\n\n        document.getElementById(\"firstName\").value = firstName;\n        document.getElementById(\"lastName\").value = lastName;\n        document.getElementById(\"phone\").value = phone;\n        document.getElementById(\"email\").value = email;\n\n        document.getElementById(\"section-register\").classList.add(\"hidden\");\n        document.getElementById(\"step-indicator\").classList.remove(\"hidden\");\n        showStep(1);\n      } else {\n        document.getElementById(\"register-message\").textContent = data.error || \"Failed.\";\n        document.getElementById(\"register-message\").classList.remove(\"hidden\");\n        btn.disabled = false;\n        btn.textContent = \"Start Application\";\n      }\n    } catch (err) {\n      document.getElementById(\"register-message\").textContent = \"Network error.\";\n      document.getElementById(\"register-message\").classList.remove(\"hidden\");\n      btn.disabled = false;\n      btn.textContent = \"Start Application\";\n    }\n  });\n\n  if (token) {\n    (async () => {\n      try {\n        const res = await fetch(`/api/professional/apply?token=${encodeURIComponent(token)}`);\n        const data = await res.json();\n\n        window.__docsUploaded__ = {};\n\n        if (data.status === \"paid\") {\n          document.getElementById(\"step-indicator\").classList.add(\"hidden\");\n          showStep(0);\n          document.getElementById(\"section-register\").classList.add(\"hidden\");\n          document.getElementById(\"paid-section\").classList.remove(\"hidden\");\n          return;\n        }\n\n        if (data.status === \"new\" || data.status === \"error\") {\n          document.getElementById(\"step-indicator\").classList.add(\"hidden\");\n          showStep(0);\n          return;\n        }\n\n        window.__token__ = token;\n        if (data.applicantId) {\n          applicantId = data.applicantId;\n          window.__applicantId__ = data.applicantId;\n        }\n\n        if (data.firstName) document.getElementById(\"reg-firstName\").value = data.firstName || \"\";\n        if (data.lastName) document.getElementById(\"reg-lastName\").value = data.lastName || \"\";\n        if (data.email) document.getElementById(\"reg-email\").value = data.email || \"\";\n        if (data.phone) document.getElementById(\"reg-phone\").value = data.phone || \"\";\n\n        document.getElementById(\"section-register\").classList.add(\"hidden\");\n\n        document.getElementById(\"firstName\").value = data.firstName || \"\";\n        document.getElementById(\"lastName\").value = data.lastName || \"\";\n        document.getElementById(\"phone\").value = data.phone || \"\";\n        document.getElementById(\"email\").value = data.email || \"\";\n        if (data.dateOfBirth) document.getElementById(\"dateOfBirth\").value = data.dateOfBirth;\n        if (data.ethnicity) document.getElementById(\"ethnicity\").value = data.ethnicity;\n        if (data.address) document.getElementById(\"address\").value = data.address;\n        if (data.postalAddress) document.getElementById(\"postalAddress\").value = data.postalAddress;\n        if (data.businessName) document.getElementById(\"businessName\").value = data.businessName;\n        if (data.website) document.getElementById(\"website\").value = data.website;\n\n        document.getElementById(\"step-indicator\").classList.remove(\"hidden\");\n\n        try {\n          const quals = JSON.parse(data.qualifications || \"[]\");\n          quals.forEach(q => addCourseRow(q));\n        } catch {}\n\n        try {\n          const exps = JSON.parse(data.experience || \"[]\");\n          exps.forEach(e => addExperienceRow(e));\n        } catch {}\n\n        try {\n          const fr = JSON.parse(data.furtherRequirements || \"{}\");\n          const setRadio = (name, val) => {\n            if (!val) return;\n            const radio = document.querySelector(`input[name=\"${name}\"][value=\"${val}\"]`);\n            if (radio) radio.checked = true;\n          };\n          setRadio(\"agreeDoulaServices\", fr.agreeDoulaServices);\n          setRadio(\"agreeInterview\", fr.agreeInterview);\n          setRadio(\"commitProfessionalDev\", fr.commitProfessionalDev);\n          setRadio(\"willInsurance\", fr.willInsurance);\n          setRadio(\"listDirectory\", fr.listDirectory);\n          setRadio(\"provideCriminalCheck\", fr.provideCriminalCheck);\n          setRadio(\"attendMeetings\", fr.attendMeetings);\n          setRadio(\"workRemotely\", fr.workRemotely);\n        } catch {}\n\n        try {\n          const comps = JSON.parse(data.coreCompetencies || \"[]\");\n          comps.forEach((c, i) => { competencyStates[i] = c; });\n          buildCompetencyGrid();\n        } catch {}\n\n        if (data.referee1) {\n          document.getElementById(\"ref1Name\").value = data.referee1.name || \"\";\n          document.getElementById(\"ref1Role\").value = data.referee1.role || \"\";\n          document.getElementById(\"ref1Email\").value = data.referee1.email || \"\";\n          document.getElementById(\"ref1Phone\").value = data.referee1.phone || \"\";\n        }\n        if (data.referee2) {\n          document.getElementById(\"ref2Name\").value = data.referee2.name || \"\";\n          document.getElementById(\"ref2Role\").value = data.referee2.role || \"\";\n          document.getElementById(\"ref2Email\").value = data.referee2.email || \"\";\n          document.getElementById(\"ref2Phone\").value = data.referee2.phone || \"\";\n        }\n\n        try {\n          const exps = JSON.parse(data.experience || \"[]\");\n          if (exps[0]?.description) document.getElementById(\"example1\").value = exps[0].description;\n          if (exps[1]?.description) document.getElementById(\"example2\").value = exps[1].description;\n          if (exps[2]?.description) document.getElementById(\"example3\").value = exps[2].description;\n        } catch {}\n\n        const isTrueFlag = (value) => String(value || \"\").toUpperCase() === \"TRUE\";\n        if (isTrueFlag(data.declarationAccuracy)) document.getElementById(\"declAccuracy\").checked = true;\n        if (isTrueFlag(data.declarationEthics)) document.getElementById(\"declEthics\").checked = true;\n        if (isTrueFlag(data.declarationScope)) document.getElementById(\"declScope\").checked = true;\n        if (isTrueFlag(data.declarationDoulaServices)) document.getElementById(\"declDoulaServices\").checked = true;\n        if (isTrueFlag(data.declarationInterview)) document.getElementById(\"declInterview\").checked = true;\n        if (isTrueFlag(data.declarationProfessionalDev)) document.getElementById(\"declProfessionalDev\").checked = true;\n        if (isTrueFlag(data.declarationCriminalCheck)) document.getElementById(\"declCriminalCheck\").checked = true;\n        if (isTrueFlag(data.declarationMeetings)) document.getElementById(\"declMeetings\").checked = true;\n\n        if (data.docsUploaded) {\n          window.__docsUploaded__ = data.docsUploaded;\n        }\n\n        document.getElementById(\"loading-overlay\").classList.add(\"hidden\");\n        showStep(1);\n      } catch (err) {\n        document.getElementById(\"loading-overlay\").classList.add(\"hidden\");\n        showStep(0);\n      }\n    })();\n  } else {\n    document.getElementById(\"loading-overlay\").classList.add(\"hidden\");\n    showStep(0);\n    buildCompetencyGrid();\n  }\n})();</script>"
